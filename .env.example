# Required — get yours at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required for Phase 1 (GitHub trending scout)
# Create at: github.com/settings/tokens → Fine-grained → repo:read scope
GITHUB_TOKEN=ghp_...

# MiroFish swarm intelligence backend (default: Docker at localhost:5001)
# Docs: https://github.com/666ghj/MiroFish
MIROFISH_URL=http://localhost:5001

# Optional — for DALL-E campaign posters/thumbnails
OPENAI_API_KEY=sk-...

# Optional — for auto-posting to Twitter
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...

# Optional — for auto-posting to Reddit
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USERNAME=...
REDDIT_PASSWORD=...

# Optional — Replicate fallback for image generation
REPLICATE_API_TOKEN=r8_...
